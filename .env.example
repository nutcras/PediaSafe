# ─── Database ─────────────────────────────────────────────────────────────────
# Connection string for the Postgres instance the API/Drizzle scripts use.
DATABASE_URL=postgresql://user:password@<postgres-host>:5432/pediasafe

# ─── API ──────────────────────────────────────────────────────────────────────
# Port the Hono API listens on.
PORT=3000
# Comma-separated CORS allowlist for the web app (defaults to "*" for dev).
CORS_ORIGIN=*
# HS256 secret used to sign/verify JWTs (use a long random value in production).
JWT_SECRET=change-me-to-a-long-random-string

# ─── Internal service networking (Docker) ─────────────────────────────────────
# How the Next.js (web) container reaches the Hono (api) container over Docker's
# internal DNS. Must match the API container_name + internal port. The browser
# never uses this — it calls relative /api/* which Next.js proxies here.
#   Docker:     http://pediasafe-api-server:3000
#   Local dev:  http://localhost:3000   (see app/web/.env.local)
INTERNAL_API_URL=http://pediasafe-api-server:3000

# ─── Docker Compose host port overrides (optional) ────────────────────────────
# Only the WEB port is published to the host; the API stays internal-only.
WEB_HOST_PORT=3101
