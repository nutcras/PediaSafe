# ─── Database ─────────────────────────────────────────────────────────────────
# ใช้ connection string จาก container ที่รันอยู่ใน db_net (api_smart-restaurant-network)
# hostname คือชื่อ container หรือ service name ของ Postgres นั้น
DATABASE_URL=postgresql://user:password@<postgres-container-name>:5432/pediasafe

# ─── LINE Messaging API ───────────────────────────────────────────────────────
# LINE Developers Console → your Messaging API channel → Basic settings
LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here

# URL ของ web app — ใช้โดย API ในการสร้าง link อนุมัติ/ฝากงาน
DASHBOARD_URL=http://localhost:3101

# ─── Web App (NEXT_PUBLIC_* baked in at BUILD time) ───────────────────────────
# LINE Developers Console → your channel → LIFF tab → LIFF ID
NEXT_PUBLIC_LIFF_ID=1234567890-xxxxxxxx

# URL ของ API ที่ browser เรียกได้ (ไม่ใช่ container name)
NEXT_PUBLIC_API_URL=http://localhost:3100

# ─── Docker Compose port overrides (optional) ─────────────────────────────────
API_HOST_PORT=3100
WEB_HOST_PORT=3101
