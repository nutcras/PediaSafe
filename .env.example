# ─── Database ─────────────────────────────────────────────────────────────────
# Connection string for the Postgres instance the API/Drizzle scripts use.
DATABASE_URL=postgresql://user:password@<postgres-host>:5432/pediasafe

# ─── API ──────────────────────────────────────────────────────────────────────
# Port the Hono API listens on.
PORT=3000
# Comma-separated CORS allowlist for the web app (defaults to "*" for dev).
CORS_ORIGIN=*

# ─── Web App (NEXT_PUBLIC_* baked in at BUILD time) ───────────────────────────
# URL of the API that the browser calls (not a container name).
NEXT_PUBLIC_API_URL=http://localhost:3000

# ─── Docker Compose port overrides (optional) ─────────────────────────────────
API_HOST_PORT=3100
WEB_HOST_PORT=3101
